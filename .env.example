# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Queue names
TASK_QUEUE=task_queue
RESULTS_QUEUE=results_queue
STATUS_EVENTS_QUEUE=status_events_queue

# Orchestrator
RESULTS_TIMEOUT_SECONDS=120
RABBITMQ_HEARTBEAT_SECONDS=60

# Worker simulation
HEAVY_COMPUTATION_DELAY_MS=2500

# Docker platform hints
# M1/M2 Mac local stack: linux/arm64
# Linux x86_64 server worker: linux/amd64
RABBITMQ_PLATFORM=linux/arm64
WORKER_PLATFORM=linux/amd64

# Legacy placeholders kept for compatibility
SERVER_IP=127.0.0.1
DB_PASSWORD=your_secret_here
